@*
    FILE        : Search/Index.cshtml
    DESCRIPTION : Search form and results page. The backend uses EF Core
                  parameterized queries to prevent SQL Injection (OWASP A03).
                  Results are paginated at 5 posts per page.
*@
@model SearchResultsViewModel
@{
    ViewData["Title"] = "Search";
}

<h2>Search Posts</h2>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="query" class="form-control" value="@Model.Query"
               placeholder="Search by post title..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Query))
{
    <h4>Results for "@Model.Query"</h4>
    <hr />
}
else
{
    <h4>All Posts</h4>
    <hr />
}

@if (Model.Results.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model.Results)
            {
                <tr>
                    <td>
                        <a asp-controller="Posts" asp-action="Detail" asp-route-id="@post.Id">
                            @post.Title
                        </a>
                    </td>
                    <td>@post.Author?.UserName</td>
                    <td><span class="badge bg-info">@post.Category?.Name</span></td>
                    <td>@post.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>

    @* Pagination *@
    <nav aria-label="Search pagination">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-query="@Model.Query"
                   asp-route-page="@(Model.Page - 1)">
                    &laquo; Previous
                </a>
            </li>

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-query="@Model.Query"
                       asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-query="@Model.Query"
                   asp-route-page="@(Model.Page + 1)">
                    Next &raquo;
                </a>
            </li>
        </ul>
    </nav>

    <p class="text-center text-muted small">
        Page @Model.Page of @Model.TotalPages
    </p>
}
else
{
    <div class="alert alert-warning">No posts found matching your search.</div>
}
