@*
    FILE        : Posts/Create.cshtml
    DESCRIPTION : Form for creating a new forum post with category selection.
*@
@model CreatePostViewModel
@{
    ViewData["Title"] = "Create Post";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <h2>Create New Post</h2>
        <hr />

        <div asp-validation-summary="All" class="text-danger"></div>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Post title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" class="form-select"
                        asp-items="@(new SelectList(Model.Categories, "Id", "Name"))">
                    <option value="">-- Select Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="8"
                          placeholder="Write your post content..."></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Submit Post</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>

            <div class="alert alert-info mt-3">
                <small>Posts require admin approval before they appear publicly.</small>
            </div>
        </form>
    </div>
</div>
