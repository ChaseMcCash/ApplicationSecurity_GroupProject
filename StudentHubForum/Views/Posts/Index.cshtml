@*
    FILE        : Posts/Index.cshtml
    DESCRIPTION : Forum listing page showing all approved posts.
*@
@model IEnumerable<Post>
@{
    ViewData["Title"] = "Forum";
}

<h2>Forum Posts</h2>
<a asp-action="Create" class="btn btn-success mb-3">Create New Post</a>
<hr />

@if (Model != null && Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Category</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Detail" asp-route-id="@post.Id">@post.Title</a>
                    </td>
                    <td>@post.Author?.UserName</td>
                    <td><span class="badge bg-info">@post.Category?.Name</span></td>
                    <td>@post.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">No posts yet.</div>
}
