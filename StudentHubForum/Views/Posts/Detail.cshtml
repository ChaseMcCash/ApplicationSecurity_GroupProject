@*
    FILE        : Posts/Detail.cshtml
    DESCRIPTION : Single post detail page with comments.
                  SECURITY: Post content uses @Model.Content (Razor default encoding)
                  which automatically HTML-encodes output, preventing XSS.
                  NEVER use @Html.Raw(Model.Content) here.
*@
@model Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-8">
        <h2>@Model.Title</h2>
        <p class="text-muted">
            By <strong>@Model.Author?.UserName</strong>
            — @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")
            — <span class="badge bg-info">@Model.Category?.Name</span>
        </p>
        <hr />

        @* SECURE: Default Razor encoding prevents XSS — script tags become harmless text *@
        <div class="post-content mb-4">
            <!-- vulnerable version for XSS demo -->
            <!-- this bypasses encoding and allows scripts to run -->
            @Html.Raw(Model.Content)
        </div>

        @* Attachments *@
        @if (Model.Attachments != null && Model.Attachments.Any())
        {
            <h5>Attachments</h5>
            <ul>
                @foreach (var file in Model.Attachments)
                {
                    <li>@file.OriginalFileName (@file.ContentType, @file.FileSizeBytes bytes)</li>
                }
            </ul>
        }

        <hr />

        @* Comments Section *@
        <h4>Comments (@Model.Comments.Count)</h4>

        @foreach (var comment in Model.Comments.OrderBy(c => c.CreatedAt))
        {
            <div class="card mb-2">
                <div class="card-body">
                    @* Comment content is also Razor-encoded — safe from XSS *@
                    <p class="card-text">@comment.Content</p>
                    <small class="text-muted">
                        @comment.Author?.UserName — @comment.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                    </small>
                </div>
            </div>
        }

        @* Add Comment Form *@
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="mt-3">
                <h5>Add a Comment</h5>
                <form asp-controller="Posts" asp-action="AddComment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="postId" value="@Model.Id" />
                    <div class="mb-3">
                        <textarea name="content" class="form-control" rows="3"
                                  maxlength="1000" required placeholder="Write your comment..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Post Comment</button>
                </form>
            </div>
        }
        else
        {
            <p><a asp-controller="Account" asp-action="Login">Login</a> to comment.</p>
        }
    </div>
</div>
