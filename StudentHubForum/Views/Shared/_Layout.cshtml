@* 
    FILE          : _Layout.cshtml
    PROJECT       : SECU2000 - Secure Client-Server Application
    PROGRAMMER    : Burhan Shibli, Tuan Thanh Nguyen, Chase Mccash
    FIRST VERSION : 2026-04-13
    DESCRIPTION   :
      Main layout template for the StudentHub Forum application.
      Provides consistent navigation, Bootstrap 5 styling, and 
      role-based menu items (Admin link only shown to Admin users).
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudentHub Forum</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        /* Profile dropdown hover trigger */
        .nav-profile-dropdown:hover > .dropdown-menu,
        .nav-profile-dropdown:focus-within > .dropdown-menu {
            display: block;
        }
        .nav-profile-dropdown .dropdown-menu {
            min-width: 200px;
            margin-top: 0;
        }
        /* Avatar circle badge */
        .nav-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: #6c757d;
            color: #fff;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 2px solid rgba(255,255,255,0.3);
            transition: border-color 0.2s, transform 0.15s;
            vertical-align: middle;
            overflow: hidden;
        }
        .nav-profile-btn {
            display: flex;
            align-items: center;
            gap: 7px;
            color: rgba(255,255,255,.85) !important;
            background: transparent;
            border: none;
            padding: 6px 10px;
            border-radius: 6px;
            transition: background 0.2s, color 0.2s;
            cursor: pointer;
            white-space: nowrap;
        }
        .nav-profile-btn:hover,
        .nav-profile-dropdown:hover .nav-profile-btn {
            background: rgba(255,255,255,0.12);
            color: #fff !important;
        }
        .nav-profile-btn:hover .nav-avatar,
        .nav-profile-dropdown:hover .nav-avatar {
            border-color: rgba(255,255,255,0.75);
            transform: scale(1.08);
        }
        .nav-profile-btn .caret-icon {
            font-size: 0.6rem;
            opacity: 0.7;
            transition: transform 0.2s;
        }
        .nav-profile-dropdown:hover .caret-icon {
            transform: rotate(180deg);
        }
    </style>
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="/">StudentHub Forum</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Posts" asp-action="Index">Forum</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Search" asp-action="Index">Search</a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Posts" asp-action="Create">New Post</a>
                        </li>
                    }
                    @* Admin panel link — only visible to Admin role users (OWASP A01) *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="nav-link text-warning" asp-controller="Admin" asp-action="Index">Admin Panel</a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav">
                    @{
                        var initials = (User.Identity?.Name ?? "?")
                            .Split('@')[0]
                            .Substring(0, 1)
                            .ToUpper();
                    }
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown nav-profile-dropdown" style="position:relative;">
                            <button class="nav-profile-btn dropdown-toggle-none" type="button"
                                    aria-haspopup="true" aria-expanded="false">
                                <span class="nav-avatar">@initials</span>
                                <span class="d-none d-lg-inline">@User.Identity.Name</span>
                                <span class="caret-icon">▼</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow"
                                style="position:absolute; right:0; top:100%;">
                                <li>
                                    <span class="dropdown-item-text text-muted small px-3 py-1">
                                        Signed in as<br />
                                        <strong>@User.Identity.Name</strong>
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider my-1" /></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                        👤 My Profile
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Posts" asp-action="Create">
                                        ✏️ New Post
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-1" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-2 py-1">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                            Logout
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-light text-center py-3 mt-5">
        <p class="mb-0">2026 StudentHub Forum — SECU2000 Application Security Project</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
