@*
    FILE        : Admin/Index.cshtml
    DESCRIPTION : Admin dashboard showing user management, pending posts,
                  and audit logs. Only accessible to Admin role (OWASP A01).
*@
@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>
<hr />

<!-- Pending Posts -->
<h3>Pending Posts (Awaiting Approval)</h3>
@if (Model.PendingPosts.Any())
{
    <table class="table table-bordered">
        <thead class="table-warning">
            <tr>
                <th>Title</th>
                <th>Author</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var post in Model.PendingPosts)
            {
                <tr>
                    <td>@post.Title</td>
                    <td>@post.Author?.UserName</td>
                    <td>@post.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <form asp-action="ApprovePost" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@post.Id" />
                            <button type="submit" class="btn btn-success btn-sm">Approve</button>
                        </form>
                        <form asp-action="DeletePost" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@post.Id" />
                            <button type="submit" class="btn btn-danger btn-sm"
                                    onclick="return confirm('Delete this post?')">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-success">No pending posts.</div>
}

<hr />

<!-- User Management -->
<h3>Registered Users</h3>
<table class="table table-bordered">
    <thead class="table-primary">
        <tr>
            <th>Email</th>
            <th>Created</th>
            <th>Banned</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr class="@(user.IsBanned ? "table-danger" : "")">
                <td>@user.Email</td>
                <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>@(user.IsBanned ? "Yes" : "No")</td>
                <td>
                    @if (!user.IsBanned)
                    {
                        <form asp-action="BanUser" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-warning btn-sm"
                                    onclick="return confirm('Ban this user?')">Ban</button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-danger">Banned</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<!-- Audit Logs (OWASP A09) -->
<h3>Recent Audit Logs</h3>
<div class="table-responsive">
    <table class="table table-sm table-striped">
        <thead class="table-dark">
            <tr>
                <th>Timestamp</th>
                <th>User</th>
                <th>Action</th>
                <th>Entity</th>
                <th>IP Address</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.RecentAuditLogs)
            {
                <tr>
                    <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@(log.UserName ?? "Anonymous")</td>
                    <td><span class="badge bg-secondary">@log.Action</span></td>
                    <td>@log.EntityType @log.EntityId</td>
                    <td>@log.IpAddress</td>
                    <td><small>@log.Details</small></td>
                </tr>
            }
        </tbody>
    </table>
</div>
