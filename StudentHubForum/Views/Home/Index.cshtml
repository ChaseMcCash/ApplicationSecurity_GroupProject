@*
    FILE        : Home/Index.cshtml
    DESCRIPTION : Home page displaying recent approved forum posts and,
                  for logged-in users, a sidebar widget showing the status
                  of their submitted posts.
*@
@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <div class="col-md-8">
        <h1>Welcome to StudentHub Forum</h1>
        <p class="lead">A secure student discussion platform — SECU2000 Project</p>
        <hr />

        <h3>Recent Posts</h3>
        @if (Model.RecentPosts != null && Model.RecentPosts.Any())
        {
            @foreach (var post in Model.RecentPosts)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-controller="Posts" asp-action="Detail" asp-route-id="@post.Id">
                                @post.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted">
                            By @post.Author?.UserName — @post.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                            — in <span class="badge bg-secondary">@post.Category?.Name</span>
                        </p>
                        @* Content is rendered with default Razor encoding — prevents XSS *@
                        <p class="card-text">@post.Content.Substring(0, Math.Min(200, post.Content.Length))...</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">No posts yet. Be the first to start a discussion!</div>
        }
    </div>

    <div class="col-md-4">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">Quick Links</div>
            <div class="card-body">
                <a asp-controller="Posts" asp-action="Create" class="btn btn-primary d-block mb-2">Create New Post</a>
                <a asp-controller="Search" asp-action="Index" class="btn btn-outline-secondary d-block mb-2">Search Posts</a>
                <a asp-controller="Upload" asp-action="Index" class="btn btn-outline-secondary d-block">Upload File</a>
            </div>
        </div>

        @* Post status widget — only shown to logged-in users *@
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="card">
                <div class="card-header bg-warning text-dark">My Post Status</div>
                <div class="card-body p-2">

                    @if (!Model.MyPendingPosts.Any() && Model.MyLastApprovedPost == null)
                    {
                        <p class="text-muted small mb-0">You have no submitted posts yet.</p>
                    }

                    @* Pending posts *@
                    @foreach (var post in Model.MyPendingPosts)
                    {
                        <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                            <span class="small text-truncate me-2" style="max-width:160px;" title="@post.Title">
                                @post.Title
                            </span>
                            <span class="badge bg-warning text-dark">Pending</span>
                        </div>
                    }

                    @* Most recent approved post *@
                    @if (Model.MyLastApprovedPost != null)
                    {
                        <div class="d-flex justify-content-between align-items-center pt-1">
                            <a asp-controller="Posts" asp-action="Detail"
                               asp-route-id="@Model.MyLastApprovedPost.Id"
                               class="small text-truncate me-2" style="max-width:160px;"
                               title="@Model.MyLastApprovedPost.Title">
                                @Model.MyLastApprovedPost.Title
                            </a>
                            <span class="badge bg-success">Approved</span>
                        </div>
                    }

                    <div class="mt-2">
                        <a asp-controller="Account" asp-action="Profile"
                           class="btn btn-sm btn-outline-secondary w-100">View All My Posts</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
