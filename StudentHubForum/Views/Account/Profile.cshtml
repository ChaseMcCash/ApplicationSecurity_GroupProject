
@*
    FILE        : Account/Profile.cshtml
    DESCRIPTION : User profile page. Allows the user to view their account info,
                  upload a profile picture, change their password, and review all
                  posts they have submitted along with each post's approval status.
*@
@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<h2>My Profile</h2>
<hr />

<div class="row">

    @* ── LEFT COLUMN: avatar + account info ── *@
    <div class="col-md-4">

        @* Avatar *@
        <div class="text-center mb-3">
            @if (!string.IsNullOrEmpty(Model.ProfilePicturePath))
            {
                <img src="/uploads/@Model.ProfilePicturePath"
                     alt="Profile picture"
                     class="rounded-circle img-thumbnail"
                     style="width:130px;height:130px;object-fit:cover;" />
            }
            else
            {
                <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center text-white"
                     style="width:130px;height:130px;font-size:2.5rem;">
                    👤
                </div>
            }
        </div>

        <p class="text-center mb-1"><strong>@Model.Email</strong></p>
        <p class="text-center text-muted small">Member since @Model.CreatedAt.ToString("MMM dd, yyyy")</p>

        @* Avatar upload form *@
        <div class="card mb-3">
            <div class="card-header">Change Profile Picture</div>
            <div class="card-body">
                @if (TempData["AvatarError"] != null)
                {
                    <div class="alert alert-danger py-1 small">@TempData["AvatarError"]</div>
                }
                @if (TempData["AvatarSuccess"] != null)
                {
                    <div class="alert alert-success py-1 small">@TempData["AvatarSuccess"]</div>
                }
                <form asp-action="UploadAvatar" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <input type="file" name="avatar" class="form-control form-control-sm"
                               accept="image/jpeg,image/png,image/gif,image/webp" required />
                        <div class="form-text">JPEG, PNG, GIF or WEBP — max 2 MB</div>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary w-100">Upload</button>
                </form>
            </div>
        </div>

        @* Change password form *@
        <div class="card">
            <div class="card-header">Change Password</div>
            <div class="card-body">
                @if (TempData["PasswordError"] != null)
                {
                    <div class="alert alert-danger py-1 small">@TempData["PasswordError"]</div>
                }
                @if (TempData["PasswordSuccess"] != null)
                {
                    <div class="alert alert-success py-1 small">@TempData["PasswordSuccess"]</div>
                }
                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label small">Current Password</label>
                        <input type="password" name="CurrentPassword" class="form-control form-control-sm" required />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">New Password</label>
                        <input type="password" name="NewPassword" class="form-control form-control-sm" required minlength="10" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Confirm New Password</label>
                        <input type="password" name="ConfirmNewPassword" class="form-control form-control-sm" required minlength="10" />
                    </div>
                    <button type="submit" class="btn btn-sm btn-warning w-100">Change Password</button>
                </form>
            </div>
        </div>

    </div>

    @* ── RIGHT COLUMN: all posts with status ── *@
    <div class="col-md-8">
        <h4>My Posts</h4>

        @if (!Model.MyPosts.Any())
        {
            <div class="alert alert-info">You have not created any posts yet.</div>
        }
        else
        {
            <table class="table table-striped table-sm">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Submitted</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model.MyPosts)
                    {
                        <tr>
                            <td>
                                @if (post.IsApproved)
                                {
                                    <a asp-controller="Posts" asp-action="Detail" asp-route-id="@post.Id">
                                        @post.Title
                                    </a>
                                }
                                else
                                {
                                    @post.Title
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@post.Category?.Name</span>
                            </td>
                            <td class="text-muted small">@post.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (post.IsApproved)
                                {
                                    <span class="badge bg-success">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pending Approval</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

</div>
